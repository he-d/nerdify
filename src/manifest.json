{
  "manifest_version": 3,
  "name": "Nerdify",
  "version": "1.0.1",
  "description": "Render any website using a Nerd Font of your choice, with global and per-site control.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/nerdify_16.png",
      "48": "icons/nerdify_48.png",
      "128": "icons/nerdify_128.png"
    }
  },
  "icons": {
    "16": "icons/nerdify_16.png",
    "48": "icons/nerdify_48.png",
    "128": "icons/nerdify_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "fonts.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}